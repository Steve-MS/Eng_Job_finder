# Mech-PM-Finder environment variables
# Copy this file to .env and fill in your API keys.
# .env is git-ignored and never committed.

# Reed.co.uk API key (free — register at https://www.reed.co.uk/developers)
REED_API_KEY=

# Adzuna API credentials (free — register at https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# OpenAI API key (optional — only needed for LLM-assisted extraction fallback)
OPENAI_API_KEY=
